# Sparks Bus — environment overrides
# Every key in config.json can be overridden here. Watcher prefers env > config.json > defaults.
# Source this file from your systemd unit (EnvironmentFile=) or shell.

# Path to config.json. If unset, watcher looks for ./config.json then ./config.example.json.
# BUS_CONFIG=/etc/sparks-bus/config.json

# DB
# BUS_DB_PATH=~/.sparks/bus.sqlite
# BUS_POLL_INTERVAL_SECONDS=30
# BUS_STALE_SECONDS=3600

# Mnemo Cortex (optional — unset/unreachable => STANDALONE mode)
# BUS_MNEMO_URL=http://localhost:50001
# BUS_MNEMO_AGENT_ID=bus

# Discord
# BUS_DISCORD_TOKEN_FILE=~/.sparks/discord-token
# BUS_DISCORD_CHANNELS_FILE=./discord-channels.json
# BUS_DISPATCH_CHANNEL=dispatch
# BUS_ALERTS_CHANNEL=alerts
